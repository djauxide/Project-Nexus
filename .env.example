# NEXUS v4 Environment Configuration
# Copy to .env and fill in values

# API
NODE_ENV=development
API_PORT=8080
JWT_SECRET=change-me-to-256-bit-random-string
LOG_LEVEL=info

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-me

# Cache
REDIS_URL=redis://localhost:6379

# Metrics
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=change-me
INFLUX_ORG=nexus-broadcast
INFLUX_BUCKET=metrics

# Object Storage
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=nexus-recordings

# Broadcast
PTP_DOMAIN=0
PTP_INTERFACE=eth0
NMOS_REGISTRY_URL=http://localhost:8010
ST2110_JITTER_BUFFER_MS=5

# Cloud (optional)
AWS_REGION=us-east-1
S3_BUCKET=nexus-recordings
